{
  "name": "webnet_app",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "update-passwords": "node scripts/update-passwords.js",
    "wipe-user-data": "node scripts/wipe-user-data.js",
    "migrate-user-shape": "node scripts/migrate-user-shape.js",
    "backfill-user-tenants": "node scripts/backfill-user-tenantid.js",
    "bulk-import-pros": "node scripts/bulk-import-professionals.js",
    "start": "expo start",
    "start:clear": "expo start --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "clean-install": "rm -rf node_modules package-lock.json && npm install",
    "sync-brand-assets": "bash scripts/sync-brand-assets.sh",
    "sync-ios-app-icon": "cp assets/icon.png ios/webnetapp/Images.xcassets/AppIcon.appiconset/App-Icon-1024x1024@1x.png",
    "deploy:firestore-rules": "firebase deploy --only firestore:rules",
    "deploy:firestore": "firebase deploy --only firestore",
    "postinstall": "node scripts/ensure-expo-font-symlink.js",
    "pod:install": "cd ios && pod install"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.8.5",
    "@react-navigation/stack": "^7.8.5",
    "babel-preset-expo": "^55.0.11",
    "expo": "~55.0.7",
    "expo-document-picker": "~55.0.9",
    "expo-font": "~55.0.6",
    "expo-file-system": "~55.0.11",
    "expo-image-manipulator": "~55.0.11",
    "expo-image-picker": "~55.0.13",
    "expo-location": "~55.1.3",
    "expo-status-bar": "~55.0.4",
    "firebase": "^12.10.0",
    "lucide-react-native": "^0.577.0",
    "nativewind": "^4.2.3",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-css-interop": "^0.2.3",
    "react-native-maps": "1.27.2",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "tailwindcss": "^3.4.19",
    "xlsx": "^0.18.5"
  },
  "private": true,
  "devDependencies": {
    "@types/react": "~19.2.10",
    "firebase-admin": "^13.7.0",
    "firebase-tools": "^14.24.0",
    "typescript": "~5.9.2"
  }
}
